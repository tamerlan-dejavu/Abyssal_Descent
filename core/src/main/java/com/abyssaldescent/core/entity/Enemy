package com.abyssaldescent.core.entity;

import com.abyssaldescent.core.entity.ai.EnemyStrategy;
import com.abyssaldescent.core.entity.state.EnemyState;
import com.abyssaldescent.core.entity.state.IdleState; // Нужно создать пустой IdleState

public class Enemy {

    private int hp;
    private EnemyStrategy strategy;
    private EnemyState state;
    private Player target;

    public Enemy(int hp, EnemyStrategy strategy) {
        this.hp = hp;
        this.strategy = strategy;
        this.state = new IdleState(); // стартовое состояние
    }

    public void update() {
        state.update(this);

        if (hp <= 0) {
            state = new DeadState();
        }
    }

    public void takeDamage(int damage) {
        hp -= damage;

        if (hp <= 0) {
            state = new DeadState();
        } else if (hp < 10) {
            state = new FleeState();
        }
    }

    public int getHp() {
        return hp;
    }

    public EnemyStrategy getStrategy() {
        return strategy;
    }

    public Player getTarget() {
        return target;
    }

    public void setTarget(Player target) {
        this.target = target;
    }

    public void setState(EnemyState state) {
        this.state = state;
    }
}