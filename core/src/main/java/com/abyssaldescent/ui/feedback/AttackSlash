package com.abyssaldescent.ui.feedback;

import com.badlogic.gdx.graphics.Color;
import com.badlogic.gdx.graphics.glutils.ShapeRenderer;
import com.abyssaldescent.event.EventBus;
import com.abyssaldescent.event.GameEvent;

import java.util.ArrayList;
import java.util.Iterator;
import java.util.List;


public class AttackSlash {

    private static final float SLASH_DURATION = 0.15f;   // сек
    private static final int   LINE_COUNT     = 5;        // линий в ударе
    private static final float SLASH_LENGTH   = 28f;      // длина каждой линии
    private static final float SLASH_SPREAD   = 18f;      // разброс по дуге (градусы)

    // Один экземпляр удара
    private static class Slash {
        float cx, cy;       // центр (мировые координаты)
        float dirX;         // направление (+1 вправо, -1 влево)
        float timer;
        boolean active;

        void init(float cx, float cy, float dirX) {
            this.cx = cx; this.cy = cy; this.dirX = dirX;
            this.timer = SLASH_DURATION;
            this.active = true;
        }
    }

    private final List<Slash> slashes = new ArrayList<>();
    private final ShapeRenderer shapeRenderer;


    public AttackSlash(EventBus eventBus, ShapeRenderer shapeRenderer) {
        this.shapeRenderer = shapeRenderer;

        // Предзаполнить пул
        for (int i = 0; i < 8; i++) slashes.add(new Slash());

        eventBus.subscribe(GameEvent.Type.PLAYER_ATTACK, event -> {
            var info = (AttackInfo) event.getPayload();
            spawn(info.worldX(), info.worldY(), info.directionX());
        });
    }


    public void update(float delta) {
        for (Slash s : slashes) {
            if (s.active) {
                s.timer -= delta;
                if (s.timer <= 0) s.active = false;
            }
        }
    }

    
    public void render() {
        for (Slash s : slashes) {
            if (!s.active) continue;

            float ratio = s.timer / SLASH_DURATION;   // 1→0
            float alpha = ratio;

            // Рисуем веер из LINE_COUNT линий
            for (int i = 0; i < LINE_COUNT; i++) {
                float t = (float) i / (LINE_COUNT - 1);   // 0..1
                float angleDeg = -SLASH_SPREAD / 2f + t * SLASH_SPREAD;
                float angleRad = (float) Math.toRadians(angleDeg);

                // Базовое направление: вправо (0°) или влево (180°)
                float baseAngle = s.dirX > 0 ? 0f : (float) Math.PI;
                float totalAngle = baseAngle + angleRad;

                float endX = s.cx + (float) Math.cos(totalAngle) * SLASH_LENGTH * ratio;
                float endY = s.cy + (float) Math.sin(totalAngle) * SLASH_LENGTH * ratio;

                // Цвет: белый → жёлтый
                float r = 1f;
                float g = 0.7f + ratio * 0.3f;
                float b = ratio * 0.5f;
                shapeRenderer.setColor(new Color(r, g, b, alpha));
                shapeRenderer.line(s.cx, s.cy, endX, endY);
            }
        }
    }


    private void spawn(float cx, float cy, float dirX) {
        for (Slash s : slashes) {
            if (!s.active) {
                s.init(cx, cy, dirX);
                return;
            }
        }
        // Пул полон — пропустить
    }


    public record AttackInfo(float worldX, float worldY, float directionX) {}
}