package com.abyssaldescent.ui.feedback;

import com.badlogic.gdx.graphics.Color;
import com.badlogic.gdx.graphics.g2d.SpriteBatch;
import com.badlogic.gdx.graphics.g2d.TextureRegion;
import com.abyssaldescent.event.EventBus;
import com.abyssaldescent.event.GameEvent;


public class HitFlash {

    private static final float FLASH_DURATION = 0.12f;   // сек белой вспышки
    private static final float BLINK_PERIOD   = 0.08f;   // сек мигания во время i-frames
    private static final float IFRAME_TOTAL   = 0.5f;    // сек i-frames (должно совпадать с PlayerStats)

    private float flashTimer  = 0f;   // белая вспышка
    private float iframeTimer = 0f;   // полное время i-frames (мигание)
    private float blinkTimer  = 0f;   // внутренний таймер мигания
    private boolean blinkVisible = true;


    public HitFlash(EventBus eventBus) {
        eventBus.subscribe(GameEvent.Type.PLAYER_DAMAGED, event -> {
            flashTimer  = FLASH_DURATION;
            iframeTimer = IFRAME_TOTAL;
            blinkVisible = true;
            blinkTimer   = 0f;
        });
    }


    public void update(float delta) {
        if (flashTimer > 0)  flashTimer  -= delta;
        if (iframeTimer > 0) {
            iframeTimer -= delta;
            blinkTimer  += delta;
            if (blinkTimer >= BLINK_PERIOD) {
                blinkTimer   = 0f;
                blinkVisible = !blinkVisible;
            }
        } else {
            blinkVisible = true;   // после i-frames всегда видим
        }
    }


    
    public boolean applyColor(SpriteBatch batch) {
        if (!blinkVisible) return false;   // пропустить кадр (мигание)

        if (flashTimer > 0) {
            
            float t = flashTimer / FLASH_DURATION;
            batch.setColor(1f, 1f, 1f, 1f);   // белый (SpriteBatch тинтует текстуру)
            
        } else {
            batch.setColor(Color.WHITE);   // нормальный цвет
        }
        return true;
    }

    /** Вернуть стандартный цвет batch ПОСЛЕ draw() спрайта. */
    public void resetColor(SpriteBatch batch) {
        batch.setColor(Color.WHITE);
    }

    public boolean isIframeActive() { return iframeTimer > 0; }
}