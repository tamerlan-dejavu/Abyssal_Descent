package com.abyssaldescent.ui.screen;

import com.badlogic.gdx.Gdx;
import com.badlogic.gdx.Input;
import com.badlogic.gdx.Screen;
import com.badlogic.gdx.graphics.Color;
import com.badlogic.gdx.graphics.GL20;
import com.badlogic.gdx.graphics.OrthographicCamera;
import com.badlogic.gdx.graphics.g2d.BitmapFont;
import com.badlogic.gdx.graphics.g2d.GlyphLayout;
import com.badlogic.gdx.graphics.g2d.SpriteBatch;
import com.badlogic.gdx.graphics.glutils.ShapeRenderer;
import com.badlogic.gdx.math.Interpolation;
import com.abyssaldescent.AbyssalDescentGame;
import com.abyssaldescent.core.save.RunStats;


public class GameOverScreen implements Screen {

    private static final float FADE_IN_DURATION   = 1.2f;   // секунд появления
    private static final float TITLE_SHAKE_AMOUNT = 4f;     // пикселей тряски
    private static final float TITLE_SHAKE_SPEED  = 18f;    // частота тряски

    private static final Color BG_COLOR     = new Color(0.04f, 0.00f, 0.02f, 1f);
    private static final Color TITLE_COLOR  = new Color(0.85f, 0.08f, 0.08f, 1f);
    private static final Color LABEL_COLOR  = new Color(0.55f, 0.55f, 0.55f, 1f);
    private static final Color VALUE_COLOR  = new Color(0.90f, 0.90f, 0.90f, 1f);
    private static final Color HINT_COLOR   = new Color(0.45f, 0.45f, 0.45f, 1f);
    private static final Color LINE_COLOR   = new Color(0.30f, 0.08f, 0.08f, 1f);

    private final AbyssalDescentGame game;
    private final RunStats           stats;

    private final OrthographicCamera camera;
    private final SpriteBatch        batch;
    private final ShapeRenderer      shapeRenderer;
    private final BitmapFont         fontTitle;   // большой
    private final BitmapFont         fontBody;    // средний
    private final BitmapFont         fontHint;    // маленький
    private final GlyphLayout        layout;

    private float fadeTimer   = 0f;
    private float shakeTimer  = 0f;
    private float alpha       = 0f;   // 0..1 (для fade-in)
    private boolean inputReady = false;  // принимать ввод только после fade-in


    public GameOverScreen(AbyssalDescentGame game, RunStats stats) {
        this.game  = game;
        this.stats = stats;

        float W = Gdx.graphics.getWidth();
        float H = Gdx.graphics.getHeight();

        camera = new OrthographicCamera();
        camera.setToOrtho(false, W, H);

        batch         = new SpriteBatch();
        shapeRenderer = new ShapeRenderer();
        layout        = new GlyphLayout();

        fontTitle = new BitmapFont();
        fontTitle.getData().setScale(3.5f);

        fontBody = new BitmapFont();
        fontBody.getData().setScale(1.3f);

        fontHint = new BitmapFont();
        fontHint.getData().setScale(0.9f);
    }


    @Override
    public void show() {
        fadeTimer  = 0f;
        shakeTimer = 0f;
        alpha      = 0f;
        inputReady = false;
    }

    @Override
    public void render(float delta) {
        update(delta);
        draw();
    }

    private void update(float delta) {
        // Fade-in
        fadeTimer += delta;
        alpha = Math.min(1f, Interpolation.fade.apply(fadeTimer / FADE_IN_DURATION));
        if (fadeTimer >= FADE_IN_DURATION) inputReady = true;

        // Тряска заголовка
        shakeTimer += delta * TITLE_SHAKE_SPEED;

        // Ввод
        if (inputReady) {
            if (Gdx.input.isKeyJustPressed(Input.Keys.ENTER)
             || Gdx.input.isKeyJustPressed(Input.Keys.ESCAPE)
             || Gdx.input.justTouched()) {
                goToMainMenu();
            }
        }
    }


    private void draw() {
        float W = Gdx.graphics.getWidth();
        float H = Gdx.graphics.getHeight();
        float cx = W / 2f;

        Gdx.gl.glClearColor(BG_COLOR.r, BG_COLOR.g, BG_COLOR.b, 1f);
        Gdx.gl.glClear(GL20.GL_COLOR_BUFFER_BIT);
        Gdx.gl.glEnable(GL20.GL_BLEND);
        Gdx.gl.glBlendFunc(GL20.GL_SRC_ALPHA, GL20.GL_ONE_MINUS_SRC_ALPHA);

        camera.update();
        shapeRenderer.setProjectionMatrix(camera.combined);
        shapeRenderer.begin(ShapeRenderer.ShapeType.Filled);

        Color lineC = new Color(LINE_COLOR.r, LINE_COLOR.g, LINE_COLOR.b, alpha);
        shapeRenderer.setColor(lineC);
        shapeRenderer.rect(cx - 120f, H * 0.56f, 240f, 1.5f);   // линия над статистикой
        shapeRenderer.rect(cx - 120f, H * 0.35f, 240f, 1.5f);   // линия под статистикой

        shapeRenderer.end();
        batch.setProjectionMatrix(camera.combined);
        batch.begin();

        // Заголовок "GAME OVER" с тряской
        float shakeOffsetX = (float) Math.sin(shakeTimer) * TITLE_SHAKE_AMOUNT * (1f - fadeTimer / FADE_IN_DURATION);
        drawCentered(fontTitle, "GAME OVER", TITLE_COLOR, cx + shakeOffsetX, H * 0.76f, alpha);

        // Строки статистики
        float statY    = H * 0.53f;
        float lineStep = 32f;
        float labelX   = cx - 110f;
        float valueX   = cx + 110f;

        drawStatRow("Время",   stats.getFormattedTime(),           labelX, valueX, statY,               alpha);
        drawStatRow("Ярус",    String.valueOf(stats.getCurrentFloor()),  labelX, valueX, statY - lineStep,    alpha);
        drawStatRow("Врагов",  String.valueOf(stats.getEnemiesKilled()), labelX, valueX, statY - lineStep * 2, alpha);
        drawStatRow("Чипов",   String.valueOf(stats.getChipsCollected()),labelX, valueX, statY - lineStep * 3, alpha);

        String hint = inputReady ? "[ ENTER ]  Главное меню" : "";
        drawCentered(fontHint, hint, HINT_COLOR, cx, H * 0.20f, alpha);

        batch.end();
    }

    private void drawStatRow(String label, String value,
                             float labelX, float valueX, float y, float a) {
        fontBody.setColor(applyAlpha(LABEL_COLOR, a));
        fontBody.draw(batch, label, labelX, y);

        layout.setText(fontBody, value);
        fontBody.setColor(applyAlpha(VALUE_COLOR, a));
        fontBody.draw(batch, value, valueX - layout.width, y);
    }

    private void drawCentered(BitmapFont font, String text, Color color,
                              float cx, float y, float a) {
        layout.setText(font, text);
        font.setColor(applyAlpha(color, a));
        font.draw(batch, text, cx - layout.width / 2f, y);
    }

    private Color applyAlpha(Color base, float a) {
        return new Color(base.r, base.g, base.b, base.a * a);
    }

    private void goToMainMenu() {
        game.setScreen(new MainMenuScreen(game));
        dispose();
    }


    @Override public void resize(int w, int h) { camera.setToOrtho(false, w, h); }
    @Override public void pause()  {}
    @Override public void resume() {}
    @Override public void hide()   {}

    @Override
    public void dispose() {
        batch.dispose();
        shapeRenderer.dispose();
        fontTitle.dispose();
        fontBody.dispose();
        fontHint.dispose();
    }
}