package com.abyssaldescent.entity;

import com.abyssaldescent.config.GameConfig;
import com.abyssaldescent.event.EventBus;
import com.abyssaldescent.event.GameEvent;

public class PlayerStats {

    public static final int BASE_DAMAGE     = 15;
    public static final int MAX_RESPAWNS    = 3;

    private int   maxHp;
    private int   currentHp;
    private int   baseDamage;
    private float speedMultiplier;   // 1.0f = норма; чип скорости даёт +0.3f
    private int   respawnsLeft;
    private boolean dead;

    private static final float I_FRAME_DURATION = 0.5f;   // секунды
    private float iFrameTimer = 0f;

    private final EventBus eventBus;


    public PlayerStats(GameConfig config, EventBus eventBus) {
        this.eventBus       = eventBus;
        this.maxHp          = config.getPlayerMaxHp();   // Easy=150 / Normal=100 / Hard=75
        this.currentHp      = maxHp;
        this.baseDamage     = BASE_DAMAGE;
        this.speedMultiplier = 1.0f;
        this.respawnsLeft   = MAX_RESPAWNS;
        this.dead           = false;
    }


    public void update(float delta) {
        if (iFrameTimer > 0) {
            iFrameTimer -= delta;
        }
    }

   
    public void takeDamage(int amount) {
        if (dead || iFrameTimer > 0) return;   // неуязвим

        currentHp = Math.max(0, currentHp - amount);
        iFrameTimer = I_FRAME_DURATION;

        eventBus.post(new GameEvent(GameEvent.Type.PLAYER_DAMAGED,
                new DamageInfo(amount, currentHp, maxHp)));

        if (currentHp == 0) {
            handleDeath();
        }
    }

    
    public void heal(int amount) {
        if (dead) return;
        currentHp = Math.min(maxHp, currentHp + amount);
        eventBus.post(new GameEvent(GameEvent.Type.PLAYER_HEALED,
                new DamageInfo(amount, currentHp, maxHp)));
    }


    private void handleDeath() {
        if (respawnsLeft > 0) {
            // Есть возрождения → ждём, пока игрок использует алтарь
            eventBus.post(new GameEvent(GameEvent.Type.PLAYER_DIED, respawnsLeft));
        } else {
            // Возрождений нет → Game Over
            dead = true;
            eventBus.post(new GameEvent(GameEvent.Type.GAME_OVER, null));
        }
    }

    
    public void respawn() {
        if (respawnsLeft <= 0) return;
        respawnsLeft--;
        currentHp = maxHp;
        dead      = false;
        iFrameTimer = 1.5f;   // небольшая неуязвимость после возрождения
        eventBus.post(new GameEvent(GameEvent.Type.PLAYER_RESPAWNED, respawnsLeft));
    }


    /** Чип Силы: +25% урон */
    public void addDamageMultiplier(float bonus) {
        baseDamage = Math.round(baseDamage * (1f + bonus));
    }

    /** Чип Скорости: +30% скорость */
    public void addSpeedMultiplier(float bonus) {
        speedMultiplier += bonus;
    }

    /** Чип Здоровья: +25 maxHp и +20 currentHp */
    public void increaseMaxHp(int bonus, int healAmount) {
        maxHp     += bonus;
        currentHp  = Math.min(maxHp, currentHp + healAmount);
        eventBus.post(new GameEvent(GameEvent.Type.PLAYER_HEALED,
                new DamageInfo(healAmount, currentHp, maxHp)));
    }

    public int   getCurrentHp()       { return currentHp; }
    public int   getMaxHp()           { return maxHp; }
    public int   getBaseDamage()      { return baseDamage; }
    public float getSpeedMultiplier() { return speedMultiplier; }
    public int   getRespawnsLeft()    { return respawnsLeft; }
    public boolean isDead()           { return dead; }
    public boolean isInvincible()     { return iFrameTimer > 0; }


    /** worldX, worldY — позиция игрока в момент удара (для цифр урона и вспышки). */
    public record DamageInfo(int amount, int currentHp, int maxHp,
                             float worldX, float worldY) {}
}