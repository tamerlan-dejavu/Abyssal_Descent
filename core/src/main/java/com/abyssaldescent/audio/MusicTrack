package com.abyssaldescent.audio;

public enum MusicTrack {

    MAIN_MENU   ("music/main_menu.ogg"),
    FLOOR_1     ("music/floor_1_ruins.ogg"),      // Ярус 1: Руины
    FLOOR_2     ("music/floor_2_caves.ogg"),       // Ярус 2: Пещеры
    FLOOR_3     ("music/floor_3_abyss.ogg"),       // Ярус 3: Бездна
    BOSS        ("music/boss_maltarion.ogg"),       // Босс Малтарион-Эхо
    GAME_OVER   ("music/game_over.ogg"),
    VICTORY     ("music/victory.ogg");

    private final String path;

    MusicTrack(String path) { this.path = path; }

    public String getPath() { return path; }

    /** Вернуть трек для яруса (1–3). */
    public static MusicTrack forFloor(int floor) {
        return switch (floor) {
            case 1  -> FLOOR_1;
            case 2  -> FLOOR_2;
            case 3  -> FLOOR_3;
            default -> FLOOR_1;
        };
    }
}