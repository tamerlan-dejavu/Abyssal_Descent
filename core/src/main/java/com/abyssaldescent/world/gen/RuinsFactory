public class RuinsFactory implements TierFactory {
    @Override
    public Tile createFloorTile() { return TileFactory.getTile(TileType.FLOOR); }
    
    @Override
    public Tile createWallTile() { return TileFactory.getTile(TileType.WALL); }

    @Override
    public Enemy createEnemy() {
       
        return new Enemy("Goblin Shadow", 15); 
    }

    @Override
    public Trap createTrap() { return new FallingStoneTrap(); }
}