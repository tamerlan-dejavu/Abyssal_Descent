package com.abyssaldescent.combat.chips;


public abstract class Chip {

    private final ChipType type;
    private final boolean passive;  
    private float x, y;             

    protected Chip(ChipType type, boolean passive) {
        this.type = type;
        this.passive = passive;
    }

    public ChipType getType()    { return type; }
    public boolean isPassive()   { return passive; }
    public float getX()          { return x; }
    public float getY()          { return y; }

    public void setPosition(float x, float y) {
        this.x = x;
        this.y = y;
    }

    
    public abstract void apply(com.abyssaldescent.entity.Player player);

    
    public void remove(com.abyssaldescent.entity.Player player) {
        
    }
}