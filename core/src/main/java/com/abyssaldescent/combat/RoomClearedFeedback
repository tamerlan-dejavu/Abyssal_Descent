package com.abyssaldescent.combat;

import com.abyssaldescent.event.EventBus;
import com.abyssaldescent.event.events.*;
import com.abyssaldescent.world.RoomManager;

public class RoomClearedFeedback {

    private static final float FEEDBACK_DURATION = 2.0f;

    private final EventBus    eventBus;
    private final RoomManager roomManager;

    public RoomClearedFeedback(EventBus eventBus, RoomManager roomManager) {
        this.eventBus    = eventBus;
        this.roomManager = roomManager;

        eventBus.subscribe(RoomClearedEvent.class, e -> {
            roomManager.openDoorsFor(e.getRoomId());
            eventBus.post(new ScreenFlashEvent(ScreenFlashEvent.FlashType.WHITE, 0.5f));
            eventBus.post(new HudBannerEvent("ROOM CLEARED!", FEEDBACK_DURATION));
            eventBus.post(new PlaySoundEvent("sfx/room_cleared.ogg"));
        });
    }
}